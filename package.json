{
  "name": "myagens",
  "version": "0.6.9",
  "description": "Remote access to Claude Code over Telegram — stream a real Claude Code agent to your phone.",
  "license": "GPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "node scripts/predev.mjs",
    "dev": "concurrently -k -n bot,panel -c blue,green \"npm run dev:bot\" \"npm run panel:watch\"",
    "dev:bot": "node scripts/dev-bot.mjs",
    "build": "npm run build:panel && tsc -p tsconfig.json",
    "build:panel": "cd panel && npm install --include=dev && npm run build",
    "panel:watch": "cd panel && npm install --include=dev && npm run build -- --watch",
    "panel:dev": "cd panel && npm run dev",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "doctor": "node scripts/doctor.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "debug": "^4.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "imapflow": "^1.4.3",
    "nodemailer": "^9.0.1",
    "systeminformation": "^5.23.5",
    "telegraf": "git+https://github.com/gyorgysh/telegraf-hardened.git#700b605c48a3b18bfc2a9323a9cf41a721c41e65",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/debug": "^4.1.13",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.10",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "concurrently": "^10.0.3",
    "tsx": "^4.19.0",
    "typescript": "^7.0.2"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0",
    "pg": "^8.13.1",
    "vosk": "^0.3.39"
  }
}
